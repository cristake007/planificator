<!DOCTYPE html>
<html lang="en" data-theme="corporate">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Planificator{% endblock %}</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdn.jsdelivr.net/npm/daisyui@5" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="{{ asset('css/app.css') }}">
</head>
<body class="min-h-screen bg-base-200 text-base-content">
<div class="angled-page min-h-screen">
    <header class="border-b border-base-300/60 bg-base-100/95">
        <div class="container mx-auto px-2 py-2">
            <a class="btn btn-neutral text-5 font-semibold normal-case" href="{{ path('dashboard') }}">Planificator</a>
            <ul class="menu menu-horizontal mt-2 gap-1 rounded-box bg-base-200 p-1">
                <li><a href="{{ path('generator_perioade') }}">Generator</a></li>
                <li><a href="{{ path('xml_formatter') }}">XML Formatter</a></li>
                <li><a href="{{ path('word_to_excel') }}">Word Converter</a></li>
            </ul>
        </div>
    </header>

    <main class="container mx-auto px-4 py-6 md:py-8">
        {% block content %}{% endblock %}
    </main>
</div>
{% block scripts %}{% endblock %}
</body>
</html>
