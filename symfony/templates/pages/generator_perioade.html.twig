{% extends 'base.html.twig' %}
{% block title %}Generator perioade{% endblock %}
{% block content %}
<div class="space-y-6">
    <div class="card bg-base-100 shadow-xl border border-base-300/70">
        <div class="card-body">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <h1 class="card-title text-5xl font-semibold">Generator perioade cursuri</h1>
                <span class="badge badge-primary badge-outline">DaisyUI layout</span>
            </div>

            <form id="scheduleForm" class="space-y-5">
                <div class="grid gap-4 lg:grid-cols-2">
                    <fieldset class="fieldset bg-base-200 rounded-box p-4">
                        <legend class="fieldset-legend text-2xl font-semibold">Input File (CSV or Excel)</legend>
                        <input class="file-input file-input-primary w-full" type="file" id="inputFile" name="input_file" accept=".csv,.xlsx,.xls" required>
                    </fieldset>
                    <fieldset class="fieldset bg-base-200 rounded-box p-4">
                        <legend class="fieldset-legend text-2xl font-semibold">Year</legend>
                        <input class="input input-primary w-full" type="number" id="year" value="2026" min="2024" max="2035" required>
                    </fieldset>
                </div>

                <fieldset class="fieldset bg-base-200 rounded-box p-4">
                    <legend class="fieldset-legend text-2xl font-semibold">Select Months</legend>
                    <div class="grid grid-cols-2 gap-2 md:grid-cols-4 lg:grid-cols-6">
                        {% for m in 1..12 %}
                            <label class="label cursor-pointer justify-start gap-3 rounded-btn bg-base-100 px-3 py-2">
                                <input class="checkbox checkbox-primary month-checkbox" type="checkbox" value="{{ m }}">
                                <span class="label-text text-xl">{{ date("2026-" ~ "%02d"|format(m) ~ "-01")|date("F") }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    <div class="join mt-2">
                        <button class="btn btn-sm join-item" type="button" onclick="selectAllMonths()">Select All</button>
                        <button class="btn btn-sm join-item" type="button" onclick="deselectAllMonths()">Deselect All</button>
                    </div>
                </fieldset>

                <fieldset class="fieldset bg-base-200 rounded-box p-4">
                    <legend class="fieldset-legend text-2xl font-semibold">Randomness</legend>
                    <input id="randomness" type="range" min="1" max="10" value="5" class="range range-primary">
                    <div class="w-full flex justify-start pt-2"><span class="badge badge-primary text-lg px-4 py-4" id="randomnessValue">5</span></div>
                </fieldset>

                <fieldset class="fieldset bg-base-200 rounded-box p-4">
                    <legend class="fieldset-legend text-2xl font-semibold">Romanian Holidays</legend>
                    <textarea id="holidayInput" class="textarea textarea-primary w-full" rows="2" placeholder="DD.MM.YYYY, one per line or comma-separated"></textarea>
                    <div class="mt-3 flex flex-wrap gap-2 items-center">
                        <button class="btn btn-outline btn-primary btn-sm" type="button" onclick="addHolidays()">Add Holidays</button>
                        <div id="holidayList" class="flex flex-wrap gap-2"></div>
                    </div>
                </fieldset>

                <div class="flex flex-wrap gap-2">
                    <button class="btn btn-primary" type="submit">Generate Schedule</button>
                    <button class="btn btn-success hidden" id="exportBtn" type="button" onclick="exportSchedule()">Export to Excel</button>
                </div>
            </form>

            <div id="loadingSpinner" class="alert hidden"><span class="loading loading-spinner loading-md"></span> Generating schedule...</div>
            <div id="errorAlert" class="alert alert-error hidden"></div>
            <div id="courseCounter" class="alert alert-info hidden"></div>
        </div>
    </div>

    <div id="scheduleResult" class="hidden rounded-box border border-base-300 bg-base-100 shadow-xl angled-panel p-3 md:p-4">
        <div class="overflow-x-auto rounded-box bg-base-100">
            <table class="table table-zebra table-md schedule-table">
                <thead>
                    <tr>
                        <th>Course Name</th>
                        <th>Days</th>
                        <th>Investitie</th>
                        {% for m in 1..12 %}<th>{{ date("2026-" ~ "%02d"|format(m) ~ "-01")|date("F") }}</th>{% endfor %}
                    </tr>
                </thead>
                <tbody id="scheduleTableBody"></tbody>
            </table>
        </div>
        <div id="schedulePagination" class="mt-4 hidden items-center justify-center gap-3">
            <button id="prevPageBtn" type="button" class="btn btn-sm">Prev</button>
            <div id="pageButtons" class="join"></div>
            <button id="nextPageBtn" type="button" class="btn btn-sm">Next</button>
        </div>
    </div>

    <div id="scheduleResult" class="hidden rounded-2xl pattern-panel p-4 md:p-6 overflow-auto">
        <table class="table table-zebra bg-base-100/95 rounded-xl">
            <thead><tr><th>Course Name</th><th>Days</th><th>Investitie</th>{% for m in 1..12 %}<th>{{ date("2026-" ~ "%02d"|format(m) ~ "-01")|date("F") }}</th>{% endfor %}</tr></thead>
            <tbody id="scheduleTableBody"></tbody>
        </table>
    </div>
</div>
{% endblock %}
{% block scripts %}<script src="{{ asset('js/app.js') }}"></script>{% endblock %}
