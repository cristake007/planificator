{% extends 'base.html.twig' %}
{% block title %}Generator perioade{% endblock %}

{% block content %}
<div class="space-y-4">
    <div class="overflow-x-auto">
        <table class="table table-xs">
            <thead>
                <tr>
                    <th colspan="2">Generator perioade cursuri</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <th>Input File (CSV or Excel)</th>
                    <td><input class="file-input file-input-xs w-full" type="file" id="inputFile" name="input_file" accept=".csv,.xlsx,.xls" required form="scheduleForm"></td>
                </tr>
                <tr>
                    <th>Year</th>
                    <td><input class="input input-xs w-full" type="number" id="year" value="2026" min="2024" max="2035" required form="scheduleForm"></td>
                </tr>
                <tr>
                    <th>Select Months</th>
                    <td>
                        <div class="grid grid-cols-2 gap-1 md:grid-cols-4 lg:grid-cols-6">
                            {% for m in 1..12 %}
                                <label class="label cursor-pointer justify-start gap-2 p-0">
                                    <input class="checkbox checkbox-xs month-checkbox" type="checkbox" value="{{ m }}" form="scheduleForm">
                                    <span class="label-text text-xs">{{ date("2026-" ~ "%02d"|format(m) ~ "-01")|date("F") }}</span>
                                </label>
                            {% endfor %}
                        </div>
                        <div class="mt-2 flex flex-wrap gap-1">
                            <button class="btn btn-xs" type="button" onclick="selectAllMonths()">Select All</button>
                            <button class="btn btn-xs" type="button" onclick="deselectAllMonths()">Deselect All</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th>Randomness</th>
                    <td>
                        <input id="randomness" type="range" min="1" max="10" value="5" class="range range-xs w-full" form="scheduleForm">
                        <span class="badge badge-xs mt-1" id="randomnessValue">5</span>
                    </td>
                </tr>
                <tr>
                    <th>Romanian Holidays</th>
                    <td>
                        <textarea id="holidayInput" class="textarea textarea-xs w-full" rows="2" placeholder="DD.MM.YYYY, one per line or comma-separated" form="scheduleForm"></textarea>
                        <div class="mt-2 flex flex-wrap gap-1">
                            <button class="btn btn-xs" type="button" onclick="addHolidays()">Add Holidays</button>
                            <div id="holidayList" class="flex flex-wrap gap-1"></div>
                        </div>
                    </td>
                </tr>
                <tr>
                    <th>Actions</th>
                    <td class="flex flex-wrap gap-1">
                        <button class="btn btn-xs" type="submit" form="scheduleForm">Generate Schedule</button>
                        <button class="btn btn-xs hidden" id="exportBtn" type="button" onclick="exportSchedule()">Export to Excel</button>
                    </td>
                </tr>
            </tbody>
        </table>
        <form id="scheduleForm" class="hidden"></form>
    </div>

    <div id="loadingSpinner" class="alert alert-info hidden"><span class="loading loading-spinner loading-xs"></span> Generating schedule...</div>
    <div id="errorAlert" class="alert alert-error hidden"></div>
    <div id="courseCounter" class="alert alert-info hidden"></div>

    <div id="scheduleResult" class="hidden overflow-x-auto">
        <table class="table table-xs">
            <thead>
                <tr>
                    <th>Course Name</th>
                    <th>Days</th>
                    <th>Investitie</th>
                    {% for m in 1..12 %}<th>{{ date("2026-" ~ "%02d"|format(m) ~ "-01")|date("F") }}</th>{% endfor %}
                </tr>
            </thead>
            <tbody id="scheduleTableBody"></tbody>
        </table>
    </div>

    <div id="schedulePagination" class="mt-2 hidden items-center gap-2">
        <button id="prevPageBtn" type="button" class="btn btn-xs">Prev</button>
        <div id="pageButtons" class="join"></div>
        <button id="nextPageBtn" type="button" class="btn btn-xs">Next</button>
    </div>
</div>
{% endblock %}

{% block scripts %}<script src="{{ asset('js/app.js') }}"></script>{% endblock %}
