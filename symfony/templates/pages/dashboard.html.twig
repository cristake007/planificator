{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block content %}
<section class="grid gap-6">
    <div class="hero rounded-2xl bg-gradient-to-r from-primary/15 via-secondary/10 to-accent/15 section-card">
        <div class="hero-content py-10 text-center">
            <div class="max-w-2xl">
                <h1 class="text-4xl font-bold">Planificator Dashboard</h1>
                <p class="py-4 text-base-content/80">A full daisyUI experience for planning workflows, exports, and conversion tools.</p>
                <div class="flex flex-wrap justify-center gap-2">
                    <a href="{{ path('generator_perioade') }}" class="btn btn-primary">Generate Schedule</a>
                    <a href="{{ path('xml_formatter') }}" class="btn btn-outline">Format XML</a>
                    <a href="{{ path('word_to_excel') }}" class="btn btn-ghost">Convert Word</a>
                </div>
            </div>
        </div>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
        <div class="card bg-base-100/90 section-card">
            <div class="card-body">
                <h2 class="card-title">Period Generator</h2>
                <p>Upload your course matrix, pick months and holidays, then generate a balanced yearly schedule.</p>
            </div>
        </div>
        <div class="card bg-base-100/90 section-card">
            <div class="card-body">
                <h2 class="card-title">XML Formatter</h2>
                <p>Turn Excel rows into valid XML output in one click with clear success and error feedback.</p>
            </div>
        </div>
        <div class="card bg-base-100/90 section-card">
            <div class="card-body">
                <h2 class="card-title">Word Converter</h2>
                <p>Match course titles from Word files to permalink sheets and export clean, usable results.</p>
            </div>
        </div>
    </div>
</section>
{% endblock %}
